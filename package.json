{
  "name": "DT-in-the-desktop",
  "version": "1.0.0",
  "description": "桌面宠物:点击换图并随机播放一段音频",
  "author": "cimeguy",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist": "electron-builder -mw"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dt.desktop",
    "productName": "DT-in-the-desktop",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "tools/cutout_person",
      "tools/cutout_person.swift",
      "assets/**",
      "!assets/download_audio/**",
      "!assets/小黑解说/**",
      "!assets/images_backup/**",
      "!assets/待用素材/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null,
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
